# Cloudflare Turnstile (form spam protection)
# Get keys from https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# Autosend API (transactional email)
# Get your key from https://autosend.com
AUTOSEND_API_KEY=your_autosend_key_here
